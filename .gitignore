# =====================================================================
# .gitignore — what NOT to commit.
#
# Conventions:
#   - source code lives in src/, rust/crates/, skills/, static/, scripts/ → all tracked
#   - generated artefacts (build output, WASM, target/) → ignored
#   - secrets and machine-local config → ignored
# =====================================================================

# --- Node / Bun ---
node_modules/
*.tsbuildinfo

# --- SvelteKit + Vite ---
/.svelte-kit/
/build/
.output/
.vercel/
.netlify/
.wrangler/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# --- Rust ---
# Build artefacts only. rust/crates/** (source code) and rust/Cargo.{toml,lock}
# are intentionally tracked — the lockfile pins versions for reproducible
# binary releases.
rust/target/

# --- Generated WASM (built by `bun run build:wasm`) ---
src/lib/wasm/

# --- Python (scripts/ may use a local venv per CLAUDE.md) ---
__pycache__/
*.py[cod]
scripts/.venv/
scripts/venv/
scripts/env/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
firebase-debug.log
firebase-debug.*.log

# --- Env / secrets (never commit) ---
.env
.env.*
!.env.example
!.env.test

# --- Editor / OS ---
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# --- Tooling artefacts ---
# Playwright-cli session data (snapshots, downloads, console logs)
.playwright-cli/
# Firebase deploy cache
.firebase/
# Firebase project/site mapping is per-deployer — commit .firebaserc.example instead
.firebaserc

# --- Claude Code (machine-local only) ---
.claude
Claude.md

# --- Misc temp ---
tmp/
*.tmp
